import wollok.game.*
import hector.*
import cultivos.*

program farmville {
	//  CONFIG	
	game.title("La granja de Héctor")
	game.height(10)
	game.width(10)
	game.ground("ground.png")

	//  VISUALES
 	game.addVisualCharacter(hector)
 	
	// TECLAS
	keyboard.m().onPressDo({ hector.plantaMaiz() })
	keyboard.r().onPressDo({ hector.rega() })
	keyboard.c().onPressDo({ hector.cosecha() })
	// TODO: Agregar las que faltan
 	
 	//  COMIENZA
	game.start()
}
