import src.cultivos.*
import src.hector.*

test "puede plantar un cultivo" {
    hector.plantaMaiz()
    const maiz = game.colliders(hector).uniqueElement()
    assert.that(game.hasVisual(maiz))
    assert.equals(hector.position(), maiz.position())
}

test "puede plantar dos cultivos" {    
    hector.plantaMaiz()
    const maiz1 = game.colliders(hector).uniqueElement()

    hector.position(hector.position().right(1))

    hector.plantaMaiz()
    const maiz2 = game.colliders(hector).uniqueElement()
    
    assert.that(game.hasVisual(maiz1))
    assert.that(game.hasVisual(maiz2))
}

test "puede regar un cultivo" {
    hector.plantaMaiz()
    const maiz = game.colliders(hector).uniqueElement()

    hector.rega()
    assert.equals("corn_adult.png", maiz.image())
}

test "puede regar un cultivo muchas veces" {
    hector.plantaMaiz()
    const maiz = game.colliders(hector).uniqueElement()

    hector.rega()
    hector.rega()
    hector.rega()
    assert.equals("corn_adult.png", maiz.image())
}

test "no puede regar en un lugar vacío" {
    assert.throwsException({ hector.rega() })
}

test "puede cosechar un cultivo" {
    hector.plantaMaiz()
    const maiz = game.colliders(hector).uniqueElement()

    hector.cosecha()
    assert.notThat(game.hasVisual(maiz))   
}